# Generated by scripts/generate-component-pages.cjs at prebuild/predev —
# regenerated from vendor/ on every build.
#
# ζ.5 follow-up (2026-05-13): per-section output. Each section dir contains
# tracked content (category index.mdx overviews + foundations root pages)
# AND generator-emitted per-component pages. Negation rules preserve the
# tracked content while still ignoring the per-component output.
src/content/docs/components/**
!src/content/docs/components/
!src/content/docs/components/*/
!src/content/docs/components/*/index.mdx

src/content/docs/brand/**
!src/content/docs/brand/
!src/content/docs/brand/*/
!src/content/docs/brand/*/index.mdx

# Foundations contains tracked root-level *.mdx (color, borders, …) +
# generator-emitted per-category subdirs. Only ignore the per-category
# subdir contents, NOT the root *.mdx files.
src/content/docs/foundations/*/**
!src/content/docs/foundations/*/index.mdx

# Generated at prebuild by scripts/fetch-state.cjs
src/data/state.json

# Generated at prebuild by scripts/sync-vendored-md.cjs
src/content/docs/accessibility.md
src/content/docs/content.md

# Generated at prebuild by scripts/generate-foundations-pages.cjs
src/content/docs/foundations/design-guidelines.mdx
src/content/docs/categories/
