---
/*
 * DerivationBanner — annotates a docs page with its relationship to the
 * knowledge substrate (volivarii/actian-ds-knowledge).
 *
 * Why this exists: docs presentation and knowledge substrate are deliberately
 * decoupled. Some pages are auto-derived from a knowledge source; others are
 * hand-authored opinionated views that *consume* substrate data (tokens, etc.)
 * without mirroring the substrate's structure. Without an explicit marker on
 * the page, contributors can't tell which is which and where to make edits.
 *
 * Props:
 * - source       Optional knowledge-side source path (e.g.
 *                "foundations/src/foundations.md"). When supplied, the page
 *                is treated as "derived from" that source.
 * - mode         "derived" — page generated/derived from source verbatim.
 *                "hand-authored" — page lives only in docs; substrate data
 *                may be imported but page structure is docs-owned.
 *                Default inferred: "derived" if source is set, else
 *                "hand-authored".
 * - note         Optional one-line explanatory note shown beside the marker.
 *
 * Visual: a compact inline strip rendered above page content. Suppressed in
 * print to keep PDFs clean.
 */

interface Props {
  source?: string;
  mode?: "derived" | "hand-authored";
  note?: string;
}

const { source, mode: modeProp, note } = Astro.props;
const mode = modeProp || (source ? "derived" : "hand-authored");

const KNOWLEDGE_REPO_URL = "https://github.com/volivarii/actian-ds-knowledge";
const sourceHref = source
  ? `${KNOWLEDGE_REPO_URL}/blob/main/${source}`
  : null;

const label = mode === "derived" ? "Derived" : "Hand-authored";
const tooltip =
  mode === "derived"
    ? "This page is regenerated from the knowledge substrate at build time. Edit the linked source file."
    : "This page is authored directly in the docs repo. It may import data from the knowledge substrate but its structure is docs-owned.";
---

<aside class="derivation-banner" data-mode={mode} aria-label={tooltip}>
  <span class="derivation-banner__chip">{label}</span>
  {sourceHref ? (
    <span class="derivation-banner__detail">
      from <a href={sourceHref} target="_blank" rel="noopener noreferrer"><code>{source}</code></a>
    </span>
  ) : (
    <span class="derivation-banner__detail">
      — page structure lives in this repo; substrate data may be imported.
    </span>
  )}
  {note && <span class="derivation-banner__note">— {note}</span>}
</aside>

<style>
  .derivation-banner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5em;
    margin: 0 0 1.25rem;
    padding: 0.4rem 0.75rem;
    font-size: 0.8125rem;
    color: var(--sl-color-text-accent);
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0.375rem;
  }
  .derivation-banner__chip {
    display: inline-flex;
    align-items: center;
    padding: 1px 0.5em;
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    background: var(--sl-color-accent-low);
    color: var(--sl-color-accent-high);
    border-radius: 0.25rem;
  }
  .derivation-banner[data-mode="hand-authored"] .derivation-banner__chip {
    background: var(--sl-color-gray-6, var(--sl-color-bg-sidebar));
    color: var(--sl-color-text);
  }
  .derivation-banner__detail code {
    font-size: 0.875em;
  }
  .derivation-banner__note {
    color: var(--sl-color-text);
    font-style: italic;
  }
  @media print {
    .derivation-banner {
      display: none;
    }
  }
</style>
