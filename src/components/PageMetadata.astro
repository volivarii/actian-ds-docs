---
import vendored from "../../vendored.json";

interface Props {
  slug: string;
  source: string;
  schema?: number;
  updated?: string;
}

const { slug, source, schema = 1, updated } = Astro.props;
const version = vendored.knowledge_repo_resolved_version || "unknown";
const updatedAt = updated || vendored.vendored_at || "";
const mdHref = Astro.url.pathname.replace(/\/$/, "") + ".md";
---

<meta name="actian-ds-slug" content={slug} />
<meta name="actian-ds-source" content={source} />
<meta name="actian-ds-version" content={version} />
<meta name="actian-ds-updated" content={updatedAt} />
<meta name="actian-ds-schema" content={String(schema)} />
<link rel="alternate" type="text/markdown" href={mdHref} />
