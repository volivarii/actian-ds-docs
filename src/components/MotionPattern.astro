---
import { getBase } from "../lib/base-url.mjs";

interface Props {
  resolvedPatterns: Array<{
    ref: { ref: string; note?: string };
    pattern: { name: string } | null;
  }>;
}
const { resolvedPatterns } = Astro.props;

// import.meta.env.BASE_URL respects astro.config.mjs `base` (e.g. "/actian-ds-docs")
// so deep links survive deploy to a base-prefixed domain.
const base = getBase(import.meta.env.BASE_URL);
---

{resolvedPatterns.map(({ ref, pattern }) => (
  <section>
    <h3>{pattern ? pattern.name : ref.ref}</h3>
    <p>
      <a href={`${base}foundations/motion#${ref.ref}`}>
        Slug: <code>{ref.ref}</code>
      </a>
    </p>
    {ref.note && <p><em>{ref.note}</em></p>}
    {!pattern && (
      <p style="color: var(--zen-color-text-error)">
        ⚠ Unresolved motion slug — build should have failed; investigate.
      </p>
    )}
  </section>
))}
