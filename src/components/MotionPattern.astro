---
import { createRequire } from "module";
import path from "path";
const require = createRequire(import.meta.url);
const loader = require(
  path.resolve(process.cwd(), "scripts/lib/category-defaults-loader.cjs"),
);

interface Props {
  patternRefs: Array<{ ref: string; note?: string }>;
}
const { patternRefs } = Astro.props;

const resolved = patternRefs.map((r) => ({
  ref: r,
  pattern: loader.resolveMotionRef(r.ref),
}));
---

{resolved.map(({ ref, pattern }) => (
  <section>
    <h3>{pattern ? pattern.name : ref.ref}</h3>
    <p>
      <a href={`/foundations/motion#${ref.ref}`}>
        Slug: <code>{ref.ref}</code>
      </a>
    </p>
    {ref.note && <p><em>{ref.note}</em></p>}
    {!pattern && (
      <p style="color: var(--zen-color-text-error)">
        ⚠ Unresolved motion slug — build should have failed; investigate.
      </p>
    )}
  </section>
))}
