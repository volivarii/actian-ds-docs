---
interface Props {
  headers: string[];
  rows: Array<Record<string, string>>;
  showSwatch?: boolean;
  swatchColumn?: string;
}

const { headers, rows, showSwatch = false, swatchColumn = "Token" } = Astro.props;

function renderCell(value: unknown): string {
  return String(value ?? "").replace(/`([^`]+)`/g, "<code>$1</code>");
}

// Detect token visual type from the token name. Returns the kind + the
// CSS var() reference for inline styling. null when no visual applies.
function tokenVisual(name: string | undefined): { kind: string; value: string } | null {
  if (!name || !name.startsWith("--")) return null;
  if (name.startsWith("--zen-color-")) return { kind: "color", value: `var(${name})` };
  if (/^--zen-spacing-/.test(name)) return { kind: "spacing", value: `var(${name})` };
  if (/^--zen-(border-radius|radius)-/.test(name)) return { kind: "radius", value: `var(${name})` };
  if (/^--zen-border-width-/.test(name)) return { kind: "border-width", value: `var(${name})` };
  return null;
}
---

<table>
  <thead>
    <tr>
      {showSwatch && <th aria-label="visual"></th>}
      {headers.map((h) => <th>{h}</th>)}
    </tr>
  </thead>
  <tbody>
    {rows.map((row) => {
      const tokenName = row[swatchColumn] || row["Token"];
      const visual = tokenVisual(tokenName);
      return (
        <tr>
          {showSwatch && (
            <td class="token-visual-cell">
              {visual && visual.kind === "color" && (
                <span class="token-chip" style={`background: ${visual.value};`}></span>
              )}
              {visual && visual.kind === "spacing" && (
                <span class="token-ruler" style={`width: ${visual.value};`}></span>
              )}
              {visual && visual.kind === "radius" && (
                <span class="token-radius" style={`border-radius: ${visual.value};`}></span>
              )}
              {visual && visual.kind === "border-width" && (
                <span class="token-border-width" style={`border-top-width: ${visual.value};`}></span>
              )}
            </td>
          )}
          {headers.map((h) => <td set:html={renderCell(row[h])} />)}
        </tr>
      );
    })}
  </tbody>
</table>

<style>
  .token-chip {
    display: inline-block;
    width: 1.25rem;
    height: 1.25rem;
    border-radius: 0.25rem;
    border: 1px solid var(--sl-color-gray-5, #ccc);
    vertical-align: middle;
  }
</style>
