---
interface Props {
  parts: Array<{ name: string; description: string }>;
}
const { parts } = Astro.props;
---

<div class="anatomy">
  <div class="anatomy__diagram" aria-hidden="true">
    <span class="anatomy__diagram-label">Anatomy diagram coming from Figma</span>
  </div>
  <ol class="anatomy__list">
    {parts.map((p, i) => (
      <li class="anatomy__item">
        <span class="anatomy__num">{i + 1}</span>
        <div class="anatomy__copy">
          <strong>{p.name}</strong>
          <div class="anatomy__desc">{p.description}</div>
        </div>
      </li>
    ))}
  </ol>
</div>
