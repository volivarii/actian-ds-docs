---
/**
 * ConfidenceChip — single source for the confidence chip markup.
 *
 * Used by:
 * - scripts/lib/render-mdx.cjs (renderConfidenceChips) — the actual chip
 *   markup emitted onto each component page; generate-component-pages.cjs
 *   just calls it and slots the result into the page header meta row.
 * - src/pages/confidence.mdx (chip examples + the level table)
 *
 * Props:
 *   variant: "high" | "medium" | "low" — drives the BEM modifier
 *   field: string — the field label rendered in the left segment
 *   value?: string — optional value rendered in the right segment; if
 *           absent, the right segment is empty (used in the level table)
 */

interface Props {
  variant: "high" | "medium" | "low";
  field: string;
  value?: string;
}
const { variant, field, value } = Astro.props;
---

<span class={`confidence-chip confidence-chip--${variant}`}>
  <span class="confidence-chip__field">{field}</span>
  <span>{value ?? ""}</span>
</span>
