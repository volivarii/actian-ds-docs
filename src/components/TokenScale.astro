---
import { resolveScale } from "../lib/token-scale-resolve.mjs";
import { flatten, autoKind } from "../lib/token-scale-flatten.mjs";

interface Props {
  /**
   * The DTCG sub-tree to render. E.g. tokens.color.primary, tokens.spacing,
   * tokens.border.radius. Pass the object directly (don't make caller flatten).
   */
  data: any;

  /**
   * Token name prefix. Used to reconstruct CSS variable names.
   * E.g. "color-primary" → tokens with names like --zen-color-primary-500.
   * Pass without the "--zen-" prefix.
   */
  prefix?: string;

  /**
   * Convenience shorthand: selects a known sub-tree of `data` and sets the
   * matching prefix automatically. Existing call sites that pass `data` +
   * `prefix` directly are unaffected.
   *
   * - "spacing" → data.spacing, prefix "spacing"
   * - "color"   → data.color,   prefix "color"
   * - "radius"  → data.border.radius, prefix "border-radius"
   * - "type"    → data.font.size, prefix "font-size"
   */
  scale?: "type" | "spacing" | "color" | "radius";

  /**
   * Visual kind. If omitted, auto-detect from prefix.
   */
  visualKind?: "color" | "spacing" | "radius" | "border-width" | "none" | "auto";

  /**
   * Whether to show the visual column. Default: true if visualKind !== "none".
   */
  showVisual?: boolean;

  /**
   * Whether to show the resolved Value column (hex / px / number).
   * Default: true. Pass `false` when the token name alone carries the
   * meaning — e.g. brand scales whose hex varies per theme and the
   * stable identifier is the CSS variable name (the primitive token
   * name in DTCG terms).
   */
  showValue?: boolean;
}

const {
  data,
  prefix,
  scale,
  visualKind = "auto",
  showVisual,
  showValue = true,
} = Astro.props;
const { effectiveData, effectivePrefix } = resolveScale(data, scale, prefix);

const kind: "color" | "spacing" | "radius" | "border-width" | "none" =
  visualKind === "auto" ? autoKind(effectivePrefix) : visualKind;
const willShowVisual = showVisual ?? kind !== "none";
const rows = flatten(effectiveData, effectivePrefix);
---

<table class="token-scale">
  <thead>
    <tr>
      {willShowVisual && <th class="token-scale__visual-th" aria-label="visual"></th>}
      <th>Token</th>
      {showValue && <th>Value</th>}
    </tr>
  </thead>
  <tbody>
    {rows.map((row) => (
      <tr>
        {willShowVisual && (
          <td class="token-scale__visual-cell">
            {kind === "color" && (
              <span class="token-chip" style={`background: var(${row.Token});`}></span>
            )}
            {kind === "spacing" && (
              <span class="token-ruler" style={`width: var(${row.Token});`}></span>
            )}
            {kind === "radius" && (
              <span class="token-radius" style={`border-radius: var(${row.Token});`}></span>
            )}
            {kind === "border-width" && (
              <span class="token-border-width" style={`border-top-width: var(${row.Token});`}></span>
            )}
          </td>
        )}
        <td><code>{row.Token}</code></td>
        {showValue && <td><code>{row.Value}</code></td>}
      </tr>
    ))}
  </tbody>
</table>
