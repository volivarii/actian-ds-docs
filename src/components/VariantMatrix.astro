---
interface Props {
  variantAxes: Array<{ axis: string; values: string[] }>;
}
const { variantAxes } = Astro.props;
---

<table>
  <thead><tr><th>Axis</th><th>Values</th></tr></thead>
  <tbody>
    {variantAxes.map((a) => (
      <tr>
        <td><strong>{a.axis}</strong></td>
        <td>{a.values.map((v) => <code style="margin-right:8px">{v}</code>)}</td>
      </tr>
    ))}
  </tbody>
</table>
