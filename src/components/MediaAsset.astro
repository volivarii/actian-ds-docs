---
// Presentational wrapper for a media asset. Receives an already-resolved
// public path (e.g. "/media/avatar/preview.png") and BASE-prefixes it for
// the runtime URL. Path resolution from the slug+role+index sidecar lives
// at MDX-generation time in scripts/lib/render-mdx.cjs — the renderer
// emits `<MediaAsset src="..." />` only when a real path resolves, so this
// component just decorates the <img>.

interface Props {
  src?: string | null;
  alt?: string;
}

const { src, alt } = Astro.props;
// Inline BASE_URL handling — `src` always starts with "/", BASE_URL ends with
// "/", so trim BASE to exactly one separator before concatenation.
const BASE = import.meta.env.BASE_URL.replace(/\/?$/, "");
const fullSrc = src ? BASE + src : null;
---

{fullSrc && (
  <figure class="actian-media">
    <img src={fullSrc} loading="lazy" alt={alt || ""} />
  </figure>
)}

<style>
  .actian-media {
    margin: 1.5rem 0 1.5rem 0;
  }
  .actian-media img {
    max-width: 100%;
    height: auto;
    display: block;
  }
</style>
