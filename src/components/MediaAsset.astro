---
import { resolveMediaPath } from "./media-asset-resolver.mjs";

interface Props {
  role: string;
  guideline?: any;
  alt?: string;
}

const { role, guideline, alt } = Astro.props;
const resolvedPath = resolveMediaPath(guideline, role);
// Inline BASE_URL handling — getBase() in src/lib/base-url.mjs normalizes to a
// trailing-slash form ("/" or "/actian-ds-docs/"), but resolveMediaPath always
// returns a leading-slash path ("/media/<slug>/<file>"). Concatenating those
// would emit a double slash. Strip the trailing slash here so BASE + path
// yields exactly one separator.
const BASE = import.meta.env.BASE_URL.replace(/\/?$/, "");
const src = resolvedPath ? BASE + resolvedPath : null;
---

{src && (
  <figure class="actian-media">
    <img src={src} loading="lazy" alt={alt || ""} />
  </figure>
)}

<style>
  .actian-media {
    margin: 0 0 1.5rem 0;
  }
  .actian-media img {
    max-width: 100%;
    height: auto;
    display: block;
    border-radius: 0.5rem;
    background: var(--sl-color-gray-6, #f3f3f3);
  }
</style>
