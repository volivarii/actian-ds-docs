---
interface Props {
  slug: string;
  name: string;
  category: string;
  categorySlug: string;
  description?: string;
  isStub?: boolean;
}
import { getBase } from "../lib/base-url.mjs";
const { slug, name, category, categorySlug, description, isStub } = Astro.props;
const base = getBase(import.meta.env.BASE_URL);
---

<a class="component-card" href={`${base}components/${categorySlug}/${slug}`}>
  <div class="component-card__name">{name}</div>
  {description && <div class="component-card__desc">{description}</div>}
  <div class="component-card__cat">
    {category}{isStub && <span class="component-card__stub"> · stub</span>}
  </div>
</a>
