---
/**
 * Renders a single design-guideline section: title (heading level passed in),
 * optional body text, and optional list/table blocks. Used by the consolidated
 * Design Guidelines foundations page. Walks nested children recursively so a
 * single component instance can render the full guideline tree.
 *
 * Source shape (foundations/dist/design-guidelines/...):
 *   - id, title, body (string), blocks (array of {type: 'list'|'table', items|headers,rows})
 *   - For directory _index.json files: same shape PLUS a children[] array of
 *     { id, title, order } pointers into sibling files. We resolve them via the
 *     bundle passed in.
 */

import TokenTable from "./TokenTable.astro";

interface Block {
  type: string;
  items?: Array<string | { do?: string; dont?: string; term?: string; rule?: string }>;
  headers?: string[];
  rows?: string[][];
  ordered?: boolean;
}

interface Section {
  id: string;
  title: string;
  body?: string;
  blocks?: Block[];
  children?: Array<{ id: string; title: string; order: number }>;
}

interface Props {
  section: Section;
  bundle: Record<string, Section>;
  level: 2 | 3 | 4 | 5;
}

const { section, bundle, level } = Astro.props;

const Heading = `h${level}` as "h2" | "h3" | "h4" | "h5";

const orderedChildren = Array.isArray(section.children)
  ? [...section.children]
      .sort((a, b) => (a.order ?? 0) - (b.order ?? 0))
      .map((c) => bundle[c.id])
      .filter(Boolean)
  : [];

// Sub-level for children. Caps at h5 so we don't generate h6+.
const childLevel = Math.min(level + 1, 5) as 2 | 3 | 4 | 5;
---

<Heading id={section.id.replaceAll("/", "-")}>{section.title}</Heading>

{section.body && <p>{section.body}</p>}

{(section.blocks || []).map((block) => {
  if (block.type === "list") {
    return (
      <ul>
        {(block.items || []).map((item) => {
          if (typeof item === "string") return <li>{item}</li>;
          if (item.do) return <li><strong>Do:</strong> {item.do}</li>;
          if (item.dont) return <li><strong>Don't:</strong> {item.dont}</li>;
          if (item.term && item.rule) return <li><strong>{item.term}:</strong> {item.rule}</li>;
          return <li>{JSON.stringify(item)}</li>;
        })}
      </ul>
    );
  }
  if (block.type === "table") {
    return <TokenTable headers={block.headers || []} rows={block.rows || []} />;
  }
  return null;
})}

{orderedChildren.map((child) => (
  <Astro.self section={child} bundle={bundle} level={childLevel} />
))}
