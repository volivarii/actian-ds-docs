{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://actian.com/ds-knowledge/foundations.json",
  "title": "Foundations source frontmatter",
  "description": "Frontmatter contract for foundations/src/*.md. Optional P8 transversal reference blocks: a11y_refs and motion_refs. Most foundations files have no frontmatter; these fields are present only where a file declares cross-cutting a11y/motion references.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "a11y_refs": {
      "type": "array",
      "description": "Accessibility subsection references this foundation touches.",
      "examples": [
        [
          { "ref": "color-contrast", "note": "semantic-over-primitive rule preserves contrast under theming" },
          { "ref": "typography" }
        ]
      ],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ref"],
        "properties": {
          "ref": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$",
            "description": "Accessibility section slug (e.g. color-contrast, typography).",
            "examples": ["color-contrast", "typography", "focus-keyboard"]
          },
          "note": {
            "type": "string",
            "description": "Optional human note on why/where the reference applies.",
            "examples": ["min-height and trigger-area tokens underpin hit-target sizing"]
          }
        }
      }
    },
    "motion_refs": {
      "type": "array",
      "description": "Motion pattern references this foundation touches.",
      "examples": [
        [
          { "ref": "drawer-open-close" },
          { "ref": "state-transitions", "note": "token bands govern component motion" }
        ]
      ],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ref"],
        "properties": {
          "ref": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$",
            "description": "Motion pattern slug (e.g. drawer-open-close, success-toast).",
            "examples": ["drawer-open-close", "success-toast", "state-transitions"]
          },
          "note": {
            "type": "string",
            "description": "Optional human note.",
            "examples": ["honors prefers-reduced-motion"]
          }
        }
      }
    }
  }
}
