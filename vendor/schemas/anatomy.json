{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://actian.com/schemas/anatomy.json",
  "title": "Component anatomy (machine-extracted, Figma-synced)",
  "description": "A normalized, medium-neutral structure tree for one component, extracted from its Figma auto-layout and regenerated on every sync. Consumers interpret it into their own medium (HTML, etc.). Recursion stops at DS-component instance boundaries (referenced by slug), so the tree is compositional.",
  "type": "object",
  "required": ["_schema_version", "slug", "kit", "quality", "root"],
  "properties": {
    "_schema_version": {
      "type": "integer",
      "description": "Dist-artifact schema version, injected by the sync writer.",
      "examples": [1]
    },
    "slug": {
      "type": "string",
      "description": "Component slug this anatomy describes (registry key).",
      "examples": ["button", "alert-banner"]
    },
    "kit": {
      "type": "string",
      "description": "Source kit the component belongs to.",
      "examples": ["dskit"]
    },
    "synced_at": {
      "type": "string",
      "description": "ISO timestamp (or date) of the sync run that produced this artifact.",
      "examples": ["2026-06-11T12:00:00Z", "2026-06-11"]
    },
    "source": {
      "type": "object",
      "description": "Figma provenance: file key + node id the tree was extracted from.",
      "examples": [{ "fileKey": "AbC123", "nodeId": "1:23" }]
    },
    "variantDefaults": {
      "type": "object",
      "description": "The default variant's property map; the base appearance is captured for this combination, and appearance.variants entries are deltas relative to it.",
      "examples": [{ "Intent": "Default", "Size": "Default" }]
    },
    "quality": {
      "type": "object",
      "description": "Self-measured extraction quality — how much of the tree normalized cleanly (a proxy for 'is this Figma well-built').",
      "examples": [
        { "nodesTotal": 7, "nodesNormalized": 7, "ratio": 1, "degraded": [] }
      ],
      "required": ["nodesTotal", "nodesNormalized", "ratio", "degraded"],
      "properties": {
        "nodesTotal": {
          "type": "integer",
          "minimum": 0,
          "description": "Total nodes visited during extraction.",
          "examples": [7]
        },
        "nodesNormalized": {
          "type": "integer",
          "minimum": 0,
          "description": "Nodes that normalized cleanly (not degraded).",
          "examples": [7]
        },
        "ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "nodesNormalized / nodesTotal — 1.0 means the whole tree mapped cleanly.",
          "examples": [1, 0.75]
        },
        "degraded": {
          "type": "array",
          "description": "Nodes that could not be normalized to flex intent (e.g. absolute-positioned), with why.",
          "examples": [
            [{ "name": "Badge overlay", "reason": "layoutMode:NONE" }]
          ],
          "items": {
            "type": "object",
            "required": ["name", "reason"],
            "properties": {
              "name": {
                "type": "string",
                "description": "Figma layer name of the degraded node.",
                "examples": ["Badge overlay"]
              },
              "reason": {
                "type": "string",
                "description": "Why the node was not normalizable.",
                "examples": ["layoutMode:NONE"]
              }
            }
          }
        },
        "structuralVariants": {
          "type": "array",
          "description": "Variant values whose subtree diverged structurally from the default (added/removed/reordered nodes), so no appearance delta was emitted there.",
          "examples": [
            [
              {
                "prop": "State",
                "value": "Hover",
                "path": "0",
                "reason": "childCount:3!=4"
              }
            ]
          ],
          "items": {
            "type": "object",
            "required": ["prop", "value", "path", "reason"],
            "properties": {
              "prop": {
                "type": "string",
                "description": "Variant axis name.",
                "examples": ["State"]
              },
              "value": {
                "type": "string",
                "description": "Variant axis value.",
                "examples": ["Hover"]
              },
              "path": {
                "type": "string",
                "description": "Dot-joined child-index path to the divergent node.",
                "examples": ["0.2"]
              },
              "reason": {
                "type": "string",
                "description": "Why alignment stopped here.",
                "examples": ["kind:text!=container"]
              }
            }
          }
        },
        "uncapturedValues": {
          "type": "array",
          "description": "Axis values with no isolable variant (others held at default) or an unparseable name, so no delta was captured.",
          "examples": [
            [
              {
                "prop": "Intent",
                "value": "Ghost",
                "reason": "no isolated variant"
              }
            ]
          ],
          "items": {
            "type": "object",
            "required": ["prop", "value", "reason"],
            "properties": {
              "prop": {
                "type": "string",
                "description": "Variant axis name.",
                "examples": ["Intent"]
              },
              "value": {
                "type": "string",
                "description": "Variant axis value.",
                "examples": ["Ghost"]
              },
              "reason": {
                "type": "string",
                "description": "Why the value was not captured.",
                "examples": ["no isolated variant"]
              }
            }
          }
        }
      }
    },
    "root": {
      "$ref": "#/$defs/node",
      "description": "The root anatomy node of the component's structure tree.",
      "examples": [{ "name": "Button", "kind": "container" }]
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": ["name", "kind"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Verbatim Figma layer name (semantic hint).",
          "examples": ["Banner container", "Label"]
        },
        "kind": { "enum": ["container", "text", "instance", "icon", "vector"] },
        "id": {
          "type": "string",
          "description": "Figma node id (stable identity for the anatomy node).",
          "examples": ["14783:7564"]
        },
        "slug": {
          "type": "string",
          "description": "For kind=instance: the resolved DS-component slug (recursion stops here).",
          "examples": ["checkbox-with-label"]
        },
        "unresolved": {
          "type": "boolean",
          "description": "For kind=instance: true when the instance's component is not in the registry (slug omitted).",
          "examples": [true]
        },
        "props": {
          "type": "object",
          "description": "For kind=instance: variant/boolean/text component properties on the instance.",
          "examples": [{ "Size": "Small", "State": "Default" }]
        },
        "text": {
          "type": "string",
          "description": "For kind=text: the characters of the text node (structure marker, not canonical copy).",
          "examples": ["Heads up"]
        },
        "tokenRefs": {
          "type": "array",
          "description": "Design-token names bound on this node (fills/strokes/radius), resolved inline.",
          "examples": [["--zen-color-surface-warning"]],
          "items": { "type": "string" }
        },
        "appearance": {
          "type": "object",
          "description": "Resolved sRGB visual values captured from Figma for this node — the render substrate; consumers emit var(--token, <value>).",
          "examples": [
            {
              "background": "#f2f6f8",
              "border": { "color": "#607d8c", "width": "1px" },
              "radius": "4px"
            },
            {
              "text": {
                "color": "#50505d",
                "size": "14px",
                "weight": 400,
                "lineHeight": "20px"
              }
            }
          ],
          "additionalProperties": false,
          "properties": {
            "background": {
              "type": "string",
              "description": "Resolved fill color.",
              "examples": ["#f2f6f8", "rgba(0, 0, 0, 0.5)"]
            },
            "backgroundToken": {
              "type": "string",
              "minLength": 1,
              "pattern": "^--",
              "description": "Published --zen-* custom property the fill is bound to (P2 name layer; key-based join, only names that exist in tokens.css with a color value). Consumers emit var(<backgroundToken>, <background>).",
              "examples": ["--zen-color-bg-selected"]
            },
            "border": {
              "description": "Resolved border color and width.",
              "examples": [{ "color": "#607d8c", "width": "1px" }],
              "$ref": "#/$defs/borderShape"
            },
            "radius": {
              "type": "string",
              "description": "Resolved corner radius (uniform or 4-value).",
              "examples": ["4px", "4px 4px 0px 0px"]
            },
            "text": {
              "description": "Resolved text properties (color, size, weight, line height, letter spacing).",
              "examples": [
                {
                  "color": "#50505d",
                  "size": "14px",
                  "weight": 400,
                  "lineHeight": "20px"
                }
              ],
              "$ref": "#/$defs/textShape"
            },
            "variants": {
              "type": "array",
              "description": "Per-variant appearance deltas relative to the base appearance (variantDefaults). Each entry scopes to one axis and its values; a null field means the base value is removed for those values.",
              "examples": [
                [
                  {
                    "prop": "Type",
                    "values": ["Danger"],
                    "background": "#dc3514"
                  }
                ]
              ],
              "items": {
                "type": "object",
                "required": ["prop", "values"],
                "additionalProperties": false,
                "properties": {
                  "prop": {
                    "type": "string",
                    "description": "Variant axis name (verbatim from Figma).",
                    "examples": ["Type", "Intent"]
                  },
                  "values": {
                    "type": "array",
                    "description": "Axis values sharing this delta.",
                    "examples": [["Danger"], ["Stopped", "Sleeping"]],
                    "items": { "type": "string" }
                  },
                  "background": {
                    "type": ["string", "null"],
                    "description": "Delta fill (null = removed).",
                    "examples": ["#dc3514", null]
                  },
                  "backgroundToken": {
                    "type": ["string", "null"],
                    "description": "Delta fill token binding (P2 name layer; null = the base binding is removed for these values).",
                    "examples": ["--zen-color-bg-selected", null]
                  },
                  "radius": {
                    "type": ["string", "null"],
                    "description": "Delta radius (null = removed).",
                    "examples": ["4px", null]
                  },
                  "border": {
                    "description": "Delta border (null = removed).",
                    "examples": [{ "color": "#dc3514", "width": "1px" }, null],
                    "anyOf": [
                      { "$ref": "#/$defs/borderShape" },
                      { "type": "null" }
                    ]
                  },
                  "text": {
                    "description": "Delta text props (null = removed).",
                    "examples": [{ "color": "#dc3514" }, null],
                    "anyOf": [
                      { "$ref": "#/$defs/textShape" },
                      { "type": "null" }
                    ]
                  },
                  "slug": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Instance content swap: the registry slug of the component this instance references for these values (e.g. a per-status icon). Replaces the node's base slug when the delta matches; never null — an unresolved variant instance captures nothing rather than removing the base glyph.",
                    "examples": ["check-circle--outline"]
                  }
                }
              }
            }
          }
        },
        "normalizable": {
          "type": "boolean",
          "description": "False when this container could not be expressed as flex intent (see rawHint).",
          "examples": [false]
        },
        "rawHint": {
          "type": "object",
          "description": "For non-normalizable nodes: minimal raw Figma positioning data for the consumer to interpret.",
          "examples": [{ "layoutMode": "NONE", "x": 12, "y": -4 }]
        },
        "layout": {
          "type": "object",
          "description": "Normalized auto-layout intent (present on flex containers), medium-neutral.",
          "examples": [
            {
              "axis": "row",
              "gap": "8px",
              "padding": {
                "top": "0px",
                "right": "0px",
                "bottom": "0px",
                "left": "0px"
              },
              "align": { "main": "center", "cross": "center" },
              "sizing": { "h": "hug", "v": "hug" }
            }
          ],
          "required": ["axis", "gap", "padding", "align", "sizing"],
          "properties": {
            "axis": { "enum": ["row", "column"] },
            "gap": {
              "type": "string",
              "description": "Item spacing as a px value.",
              "examples": ["8px"]
            },
            "gapToken": {
              "type": "string",
              "minLength": 1,
              "pattern": "^--",
              "description": "Published --zen-* length custom property the item spacing is bound to (P2 name layer; length-gated join). Consumers emit gap:var(<gapToken>, <gap>).",
              "examples": ["--zen-spacing-200"]
            },
            "padding": {
              "type": "object",
              "description": "Per-side padding as px values.",
              "examples": [
                {
                  "top": "16px",
                  "right": "16px",
                  "bottom": "16px",
                  "left": "16px"
                }
              ],
              "required": ["top", "right", "bottom", "left"],
              "properties": {
                "top": {
                  "type": "string",
                  "description": "Top padding.",
                  "examples": ["16px"]
                },
                "right": {
                  "type": "string",
                  "description": "Right padding.",
                  "examples": ["16px"]
                },
                "bottom": {
                  "type": "string",
                  "description": "Bottom padding.",
                  "examples": ["16px"]
                },
                "left": {
                  "type": "string",
                  "description": "Left padding.",
                  "examples": ["16px"]
                }
              }
            },
            "paddingTokens": {
              "type": "object",
              "description": "Published --zen-* length custom property each padding side is bound to (P2 name layer; length-gated). Only bound sides appear. Consumers emit each side as var(<paddingTokens.side>, <padding.side>).",
              "examples": [
                { "top": "--zen-spacing-150", "left": "--zen-spacing-100" }
              ],
              "properties": {
                "top": {
                  "type": "string",
                  "minLength": 1,
                  "pattern": "^--",
                  "description": "Top padding length token.",
                  "examples": ["--zen-spacing-150"]
                },
                "right": {
                  "type": "string",
                  "minLength": 1,
                  "pattern": "^--",
                  "description": "Right padding length token.",
                  "examples": ["--zen-spacing-100"]
                },
                "bottom": {
                  "type": "string",
                  "minLength": 1,
                  "pattern": "^--",
                  "description": "Bottom padding length token.",
                  "examples": ["--zen-spacing-150"]
                },
                "left": {
                  "type": "string",
                  "minLength": 1,
                  "pattern": "^--",
                  "description": "Left padding length token.",
                  "examples": ["--zen-spacing-100"]
                }
              }
            },
            "align": {
              "type": "object",
              "description": "Main- and cross-axis alignment.",
              "examples": [{ "main": "center", "cross": "center" }],
              "required": ["main", "cross"],
              "properties": {
                "main": { "enum": ["start", "center", "end", "space-between"] },
                "cross": {
                  "enum": ["start", "center", "end", "baseline", "stretch"]
                }
              }
            },
            "sizing": {
              "type": "object",
              "description": "Horizontal/vertical sizing behaviour.",
              "examples": [{ "h": "hug", "v": "hug" }],
              "required": ["h", "v"],
              "properties": {
                "h": { "enum": ["hug", "fill", "fixed"] },
                "v": { "enum": ["hug", "fill", "fixed"] }
              }
            }
          }
        },
        "children": {
          "type": "array",
          "description": "Child anatomy nodes (absent for instances — recursion stops at instance boundaries).",
          "examples": [[{ "name": "Label", "kind": "text", "text": "Go" }]],
          "items": { "$ref": "#/$defs/node" }
        }
      },
      "additionalProperties": false
    },
    "borderShape": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "color": {
          "type": "string",
          "description": "Stroke color as sRGB hex or rgba.",
          "examples": ["#607d8c"]
        },
        "colorToken": {
          "type": "string",
          "minLength": 1,
          "pattern": "^--",
          "description": "Published --zen-* custom property the stroke color is bound to (P2 name layer; key-based join, only names that exist in tokens.css with a color value). Consumers emit var(<colorToken>, <color>).",
          "examples": ["--zen-color-primary-500"]
        },
        "width": {
          "type": "string",
          "description": "Stroke weight as px value.",
          "examples": ["1px"]
        }
      }
    },
    "textShape": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "color": {
          "type": "string",
          "description": "Text fill color as sRGB hex or rgba.",
          "examples": ["#50505d"]
        },
        "colorToken": {
          "type": "string",
          "minLength": 1,
          "pattern": "^--",
          "description": "Published --zen-* custom property the text color is bound to (P2 name layer). Consumers emit var(<colorToken>, <color>).",
          "examples": ["--zen-color-text-secondary"]
        },
        "size": {
          "type": "string",
          "description": "Font size as px value.",
          "examples": ["14px"]
        },
        "weight": {
          "type": "number",
          "description": "Font weight (100, 200, ..., 900).",
          "examples": [400, 600, 700]
        },
        "lineHeight": {
          "type": "string",
          "description": "Line height as a px value.",
          "examples": ["20px"]
        },
        "letterSpacing": {
          "type": "string",
          "description": "Letter spacing as px value.",
          "examples": ["0.14px"]
        }
      }
    }
  }
}
