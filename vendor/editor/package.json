{
  "name": "actian-ds-knowledge-editor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Schema-driven editor for the actian-ds-knowledge substrate. Authors edit canonical files locally; the editor packages each change as a PR against main.",
  "scripts": {
    "build:tokens": "node scripts/build-tokens.mjs",
    "predev": "npm run build:tokens",
    "prebuild": "npm run build:tokens",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --test --import tsx tests/**/*.test.ts tests/**/*.test.tsx"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.0",
    "@radix-ui/themes": "^3.2.1",
    "@rjsf/core": "^5.24.13",
    "@rjsf/utils": "^5.24.13",
    "@rjsf/validator-ajv8": "^5.24.13",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^29.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.6"
  }
}
