    {
      "@id": "pattern:access-request-management",
      "@type": "UXPattern",
      "title": "Access request management",
      "description": "Table with Requester, Item, Status, Actions. Status tabs: Pending / Done."
    },
    {
      "@id": "pattern:access-request-workflow",
      "@type": "UXPattern",
      "title": "Access request workflow",
      "description": "Request Access button, form with Use Case dropdown, 6 statuses, policy-driven approval."
    },
    {
      "@id": "pattern:activity-timeline",
      "@type": "UXPattern",
      "title": "Activity timeline",
      "description": "Chronological timeline with date headers, user avatars, action descriptions."
    },
    {
      "@id": "pattern:ai-analyst-panel",
      "@type": "UXPattern",
      "title": "AI Analyst Panel",
      "description": "Conversational analytics assistant (AI Analyst, formerly Wobby) for business users to query and understand data in natural language."
    },
    {
      "@id": "pattern:analytics-dashboard",
      "@type": "UXPattern",
      "title": "Analytics dashboard",
      "description": "Completion cards, adoption rate charts, popular items, frequent searches."
    },
    {
      "@id": "pattern:ask-ai",
      "@type": "UXPattern",
      "title": "Ask AI",
      "description": "Natural language query search through the knowledge graph with AI-generated summaries."
    },
    {
      "@id": "pattern:asset-detail-360",
      "@type": "UXPattern",
      "title": "360-degree asset detail view",
      "description": "Every catalog object has a tabbed detail page with property panel/sidebar."
    },
    {
      "@id": "pattern:bulk-edit",
      "@type": "UXPattern",
      "title": "Bulk Edit",
      "description": "Multi-item batch update of properties, contacts, and glossary links across the catalog."
    },
    {
      "@id": "pattern:data-profiling-sampling",
      "@type": "UXPattern",
      "title": "Data profiling and sampling",
      "description": "Statistical graphs on fields (profiling) and sample data preview rows (sampling)."
    },
    {
      "@id": "pattern:data-steward-agent-panel",
      "@type": "UXPattern",
      "title": "Data Steward Agent Panel",
      "description": "AI metadata-curation agent panel with approval-gated writes, tenant memory, and plan mode, assisting stewards in Studio."
    },
    {
      "@id": "pattern:discussion-threads",
      "@type": "UXPattern",
      "title": "Discussion threads",
      "description": "Available on Dataset detail pages. Users create threads, reply, edit own messages."
    },
    {
      "@id": "pattern:documentation-completion-dashboard",
      "@type": "UXPattern",
      "title": "Documentation Completion Dashboard",
      "description": "Stewardship dashboard of per-item documentation-completion percentages and the criteria contributing to each score."
    },
    {
      "@id": "pattern:federated-catalog",
      "@type": "UXPattern",
      "title": "Federated Catalog",
      "description": "Multi-catalog federation with scoped permissions and cross-catalog search."
    },
    {
      "@id": "pattern:federated-knowledge-graph",
      "@type": "UXPattern",
      "title": "Federated knowledge graph",
      "description": "Underlying architecture connecting all metadata with domain-specific ontologies."
    },
    {
      "@id": "pattern:filter-groups-form",
      "@type": "UXPattern",
      "title": "Filter-groups edit form with sticky footer",
      "description": "Edit-group / permission / role configuration pattern. Page header + top inputs section + one or more collapsible filter-group sections, each containing label rows with toggle switches, plus optional slot cards for nested config (Checkbox + Toggle stacks). Sticky footer pinned at the bottom for save/cancel actions. Used when administrators configure access bundles or named groups with many fine-grained permissions."
    },
    {
      "@id": "pattern:import-wizard",
      "@type": "UXPattern",
      "title": "Multi-step import wizard",
      "description": "6-step horizontal stepper (Connection → Items → Curator → Contact → Data Product → Confirm)."
    },
    {
      "@id": "pattern:interactive-graph",
      "@type": "UXPattern",
      "title": "Interactive graph visualization",
      "description": "Used for lineage (DAG), View 360 (radial knowledge graph), and Data Model (ER diagram). Nodes are clickable."
    },
    {
      "@id": "pattern:lineage-graph",
      "@type": "UXPattern",
      "title": "Lineage Graph",
      "description": "Directional data-flow graph with field-level path highlighting and an incomplete-process filter; rendered from data-process input/output edges."
    },
    {
      "@id": "pattern:marketplace-browsing",
      "@type": "UXPattern",
      "title": "Marketplace browsing",
      "description": "Explorer homepage: search-first with curated sections (carousels, filter chips, topic cards)."
    },
    {
      "@id": "pattern:mcp-server",
      "@type": "UXPattern",
      "title": "Actian MCP Server",
      "description": "7 tools for AI integrations (Find Glossary, Semantic Search, Get Data Model, etc.)."
    },
    {
      "@id": "pattern:metamodel-designer",
      "@type": "UXPattern",
      "title": "Metamodel Designer",
      "description": "Drag-and-drop configuration of templates and properties per item type in Studio Catalog Design."
    },
    {
      "@id": "pattern:notification-system",
      "@type": "UXPattern",
      "title": "Notification system",
      "description": "Bell icon with unread counter. Three notification types with click-to-action redirects."
    },
    {
      "@id": "pattern:right-sliding-drawer",
      "@type": "UXPattern",
      "title": "Right sliding drawer",
      "description": "Opens from list row click. Studio: quick edit. Explorer: quick view with Request Access."
    },
    {
      "@id": "pattern:search-filtered-table",
      "@type": "UXPattern",
      "title": "Search-filtered list table",
      "description": "List table with an inline Search input directly above it (no separate filter sidebar). Common for member directories, group lists, scanner inventories, connection lists. Pairs Page header → Search → Table. Search filters table contents in place; no other facets."
    },
    {
      "@id": "pattern:smart-suggestions",
      "@type": "UXPattern",
      "title": "Smart suggestions",
      "description": "AI-powered metadata enrichment: suggestion counts inline, dedicated Suggestions tab."
    },
    {
      "@id": "pattern:suggestion-workflow",
      "@type": "UXPattern",
      "title": "Suggestion workflow",
      "description": "Explorer users submit suggestions, curators review (accept/decline with comment)."
    },
    {
      "@id": "pattern:table-with-tabs",
      "@type": "UXPattern",
      "title": "Tab-filtered dashboard table",
      "description": "Page header → Tabs → Table layout. Tabs split the table by status (Active / Pending / Archived), type (My / Shared / All), or role-scoped view. Used for admin dashboards, queue views, and any list where users mentally pre-filter by category before scanning rows."
    },
    {
      "@id": "pattern:template-builder",
      "@type": "UXPattern",
      "title": "Drag-and-drop template builder",
      "description": "Studio feature for creating documentation templates via Catalog Design page."
    },
    {
      "@id": "pattern:topic-browse",
      "@type": "UXPattern",
      "title": "Topic Browse",
      "description": "Curated topic collections browsed via carousel + selector + favorites for business-user discovery."
    },
    {
      "@id": "pattern:type-picker-grid",
      "@type": "UXPattern",
      "title": "Type picker grid",
      "description": "Grid of type tiles with color-coded icons for New Item creation."
    },
    {
      "@id": "term:access-request-policy",
      "@type": "Term",
      "title": "Access Request Policy",
      "definition": "Rules governing the approval workflow for data access",
      "hiddenLabels": [
        "access control"
      ]
    },
    {
      "@id": "term:administration",
      "@type": "Term",
      "title": "Administration",
      "definition": "Config/settings app",
      "hiddenLabels": [
        "admin app"
      ]
    },
    {
      "@id": "term:ai-ready",
      "@type": "Term",
      "title": "AI Ready",
      "definition": "Auto-tag on Topics with well-documented items",
      "hiddenLabels": [
        "indexed",
        "searchable"
      ]
    },
