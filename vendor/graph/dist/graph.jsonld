      "title": "Wizards"
    },
    {
      "@id": "entity:access-request",
      "@type": "DomainEntity",
      "title": "Access Request",
      "description": "Consumer request for data-product/item access, submitted in Explorer with a required use-case justification. Accepted ≠ Granted (provisioned); processing happens in external systems (ServiceNow/Jira/owner) and status is tracked in Explorer."
    },
    {
      "@id": "entity:api-key",
      "@type": "DomainEntity",
      "title": "API Key",
      "description": "Machine-to-machine auth with 5 scopes"
    },
    {
      "@id": "entity:catalog-object",
      "@type": "DomainEntity",
      "title": "Catalog Object",
      "description": "Any indexed item. Types: Dataset, Field, Visualization, Data Process, Data Product, Glossary Item, Custom Item"
    },
    {
      "@id": "entity:connection",
      "@type": "DomainEntity",
      "title": "Connection",
      "description": "Configuration for a data source connector (91 pre-built across 16 categories)"
    },
    {
      "@id": "entity:contact",
      "@type": "DomainEntity",
      "title": "Contact",
      "description": "A person assigned a responsibility on a catalog item (e.g. Owner, Steward). Distinct from a user-group; surfaces on the item detail \"People\" section."
    },
    {
      "@id": "entity:custom-item",
      "@type": "DomainEntity",
      "title": "Custom Item",
      "description": "A user-defined custom item type extending the catalog metamodel."
    },
    {
      "@id": "entity:data-contract",
      "@type": "DomainEntity",
      "title": "Data Contract",
      "description": "Formal agreement on an Output Port (ODCS YAML descriptor) defining schema, quality thresholds, access permissions, and validation rules."
    },
    {
      "@id": "entity:data-process",
      "@type": "DomainEntity",
      "title": "Data Process",
      "description": "A transformation/pipeline catalog item. Its input/output connections to datasets (and custom items) generate the horizontal data lineage graph; supports field-level lineage."
    },
    {
      "@id": "entity:data-product",
      "@type": "DomainEntity",
      "title": "Data Product",
      "description": "Curated, business-ready asset. Contains Input Ports and Output Ports. Published to the marketplace via an ODPS YAML descriptor; access requests target the output-port level (each governed by a data-contract)."
    },
    {
      "@id": "entity:dataset",
      "@type": "DomainEntity",
      "title": "Dataset",
      "description": "A dataset asset contained by a data product; a type of catalog object. Has a schema of Fields; becomes an orphan when removed from its source connection."
    },
    {
      "@id": "entity:discussion-thread",
      "@type": "DomainEntity",
      "title": "Discussion Thread",
      "description": "Conversation thread on Dataset detail pages"
    },
    {
      "@id": "entity:domain",
      "@type": "DomainEntity",
      "title": "Domain",
      "description": "Organizational/business unit owning a set of data assets"
    },
    {
      "@id": "entity:field",
      "@type": "DomainEntity",
      "title": "Field",
      "description": "A column within a dataset's schema. Auto-created on import; participates in field-level lineage. Business keys (BK) are editable by Data Stewards."
    },
    {
      "@id": "entity:glossary-item",
      "@type": "DomainEntity",
      "title": "Glossary Item",
      "description": "A glossary item — business term, KPI, report, or domain — in the business glossary, linked to technical assets. Glossary item types are tenant-defined, with parent-child hierarchies (e.g. Business Object → Business Attribute); domain is a built-in sub-type."
    },
    {
      "@id": "entity:governance-policy",
      "@type": "DomainEntity",
      "title": "Governance Policy",
      "description": "Access rules, quality rules, compliance constraints"
    },
    {
      "@id": "entity:input-port",
      "@type": "DomainEntity",
      "title": "Input Port",
      "description": "An input port of a data product — a defined ingestion point that feeds the product."
    },
    {
      "@id": "entity:lineage",
      "@type": "DomainEntity",
      "title": "Lineage",
      "description": "Field-level transformation tracking from source to downstream"
    },
    {
      "@id": "entity:metadata",
      "@type": "DomainEntity",
      "title": "Metadata",
      "description": "Metadata attached to a catalog object — descriptive, technical, and business attributes."
    },
    {
      "@id": "entity:observability-signal",
      "@type": "DomainEntity",
      "title": "Observability Signal",
      "description": "Quality score, freshness, usage stats attached to assets"
    },
    {
      "@id": "entity:output-port",
      "@type": "DomainEntity",
      "title": "Output Port",
      "description": "An output port of a data product — a published interface that a data contract can attach to."
    },
    {
      "@id": "entity:property",
      "@type": "DomainEntity",
      "title": "Property",
      "description": "A typed metadata field definition in the catalog metamodel (8 value types). Importance (Standard/Important/Required) feeds the documentation-completion score. Configured in Studio Catalog Design."
    },
    {
      "@id": "entity:responsibility",
      "@type": "DomainEntity",
      "title": "Responsibility",
      "description": "A named contact role-type (Data Owner, Data Steward, Reader…), defined in Studio Catalog Design and assignable to any catalog item. Tenant-configurable."
    },
    {
      "@id": "entity:scanner",
      "@type": "DomainEntity",
      "title": "Scanner",
      "description": "External data ingestion agent that discovers and imports metadata from connections"
    },
    {
      "@id": "entity:suggestion",
      "@type": "DomainEntity",
      "title": "Suggestion",
      "description": "A suggested enrichment or change on a catalog object, pending steward review."
    },
    {
      "@id": "entity:template",
      "@type": "DomainEntity",
      "title": "Template",
      "description": "The documentation structure (ordered sections + properties) applied to an item type. Authored in Studio Catalog Design."
    },
    {
      "@id": "entity:topic",
      "@type": "DomainEntity",
      "title": "Topic",
      "description": "A curated collection of catalog items for business-user navigation in Explorer (carousel + browse). Created and curated by stewards in Studio. Replaces the deprecated \"Category\" concept."
    },
    {
      "@id": "entity:use-case",
      "@type": "DomainEntity",
      "title": "Use Case",
      "description": "A built-in catalog item describing an analytical use case. Required as justification when a consumer submits an access request in Explorer."
    },
    {
      "@id": "entity:user-group",
      "@type": "DomainEntity",
      "title": "User / Group",
      "description": "Identity and role assignments. Groups: Explorer, Data Steward, Super Admin"
    },
    {
      "@id": "entity:visualization",
      "@type": "DomainEntity",
      "title": "Visualization",
      "description": "A BI report or dashboard catalog item (Power BI, Tableau, Looker, Qlik…), auto-discovered by a connector and surfaced in lineage. Distinct from a dataset."
    },
    {
      "@id": "entity:watchlist",
      "@type": "DomainEntity",
      "title": "Watchlist",
      "description": "Saved filter shortcut on Studio Dashboard"
    },
